<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Sunscreen Advisor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="bg-orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <main class="container">
    <section class="card glass-card error-card" id="error-card">
      <div class="error-icon">⚠️</div>
      <h1><%= title %></h1>
      <p class="error-message"><%= message %></p>
      <a href="/" class="btn btn-primary" id="btn-retry">
        <span class="btn-icon">↩</span> Go Back & Try Again
      </a>
    </section>
  </main>

  <footer class="footer">
    <p>Powered by <a href="https://www.openuv.io/" target="_blank" rel="noopener">OpenUV API</a> · Built with Express.js &amp; Axios</p>
  </footer>
</body>
</html>
